{
  "info": {
    "_postman_id": "iot-security-platform-collection",
    "name": "IoT Security Platform API",
    "description": "Complete REST API collection for the IoT Security Platform.\n\nIncludes all device management, system health, metrics, alerts, anomalies, vulnerabilities, pipeline control, and compliance endpoints.\n\nImported from the committed OpenAPI 3.1.0 specification.\n\n## Setup\n1. Import the companion environment file (IoT Security Platform Environment)\n2. Set the `base_url` variable to your backend address (default: http://localhost:8000)\n3. Start making requests!",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Devices",
      "description": "IoT device management — list, register, update, delete, telemetry.",
      "item": [
        {
          "name": "List devices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/devices?status=online&device_type=sensor",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "devices"],
              "query": [
                {
                  "key": "status",
                  "value": "online",
                  "description": "Filter devices by connectivity status (online | offline | maintenance).",
                  "disabled": true
                },
                {
                  "key": "device_type",
                  "value": "sensor",
                  "description": "Filter devices by hardware type (e.g. sensor, gateway, camera).",
                  "disabled": true
                }
              ]
            },
            "description": "Returns a paginated list of all registered IoT devices. Supports optional filtering by device status and type. Results are sorted by last_seen descending."
          },
          "response": [
            {
              "name": "200 — Device list",
              "originalRequest": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/v1/devices",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "devices"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": \"dev-001\",\n    \"name\": \"Temperature Sensor A\",\n    \"device_type\": \"sensor\",\n    \"status\": \"online\",\n    \"risk_score\": 12.5,\n    \"compliance_score\": 94.0,\n    \"last_seen\": \"2026-05-14T10:30:00Z\"\n  }\n]"
            }
          ]
        },
